<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Universal Downloader</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            max-width: 600px;
            margin: 50px auto;
            padding: 20px;
            background-color: #f9f9f9;
        }
        h1 { text-align: center; }
        form { margin-top: 30px; text-align: center; }
        input[type="text"] {
            width: 80%;
            padding: 10px;
            font-size: 16px;
        }
        button {
            padding: 10px 20px;
            font-size: 16px;
            margin-left: 10px;
        }
        .message { margin-top: 20px; text-align: center; font-weight: bold; }
        a { color: #007bff; text-decoration: none; }
    </style>
</head>
<body>
    <h1>Universal Downloader</h1>
    <form action="/download" method="POST">
        <input type="text" name="url" placeholder="Paste URL here" required>
        <button type="submit">Download</button>
    </form>

    <% if (message) { %>
        <div class="message"><%= message %></div>
    <% } %>
</body>
</html>