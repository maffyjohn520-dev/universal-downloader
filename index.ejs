<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Universal Downloader Pro</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
<style>
    body { background: #f0f0f0; font-family: Arial, sans-serif; }
    .container { max-width: 700px; margin-top: 50px; }
    .download-link { margin-top: 20px; }
</style>
</head>
<body>
<div class="container text-center">
    <h1>Universal Downloader Pro</h1>
    <p>Paste your URL below and choose format (video/audio)</p>
    <form action="/download" method="POST">
        <input type="url" name="url" class="form-control mb-2" placeholder="Enter URL" required>
        <select name="type" class="form-select mb-2">
            <option value="video" selected>Video</option>
            <option value="audio">Audio (MP3)</option>
        </select>
        <button type="submit" class="btn btn-primary w-100">Download</button>
    </form>

    <% if (file) { %>
        <% if (file.startsWith('Error')) { %>
            <div class="alert alert-danger mt-3"><%= file %></div>
        <% } else { %>
            <div class="download-link alert alert-success mt-3">
                ✅ Downloaded: 
                <a href="/downloads/<%= file.name %>" target="_blank"><%= file.name %></a>
                (<%= file.size %> MB)
            </div>
        <% } %>
    <% } %>
</div>
</body>
</html>
